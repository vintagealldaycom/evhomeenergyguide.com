---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { pillars } from '../../config/site';

export async function getStaticPaths() {
  return pillars.map((p) => ({ params: { slug: p.slug }, props: { pillar: p } }));
}

const { pillar } = Astro.props;
const posts = (await getCollection('blog', ({ data }) => !data.draft && data.category === pillar.slug))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Group posts by subcategory
const groups = new Map<string, typeof posts>();
for (const sub of pillar.subcategories) groups.set(sub, []);
groups.set('More guides', []);
for (const p of posts) {
  const key = p.data.subcategory && groups.has(p.data.subcategory) ? p.data.subcategory : 'More guides';
  groups.get(key)!.push(p);
}
const dateFmt = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<Base title={`${pillar.title} Guides`} description={`${pillar.description} Practical, plain-English guides on ${pillar.title.toLowerCase()} from EV Home Energy Guide.`}>
  <section class="container cat-hero" style={`--pc:${pillar.color}`}>
    <span class="cat-eyebrow">Category hub</span>
    <h1>{pillar.title}</h1>
    <p>{pillar.description}</p>
    <div class="cat-subnav">
      {pillar.subcategories.map((s) => (
        <a href={`#${s.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}>{s}</a>
      ))}
    </div>
  </section>

  <section class="container">
    {[...groups.entries()].filter(([, list]) => list.length > 0).map(([sub, list]) => (
      <div class="cat-group" id={sub.toLowerCase().replace(/[^a-z0-9]+/g, '-')}>
        <h2>{sub}</h2>
        <div class="cat-grid">
          {list.map((p) => (
            <a href={`/blog/${p.id}/`} class="cat-card">
              {/* Update 4.4.2 #3 — 16:9 image placeholder (1200×675), swap in real art later */}
              <div class="cat-media" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="34" height="34" fill="currentColor"><path d="M21 19V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2zM8.5 13.5l2.5 3 3.5-4.5L19 18H5l3.5-4.5z"/></svg>
                <span class="cat-media-tag">1200 × 675</span>
              </div>
              <div class="cat-body">
                <h3>{p.data.title}</h3>
                <p>{p.data.description}</p>
                <time datetime={p.data.pubDate.toISOString()}>{dateFmt.format(p.data.pubDate)}</time>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}
    {posts.length === 0 && (
      <p class="cat-empty">Guides for this category are being migrated. Check back soon — or <a href="/en/sim-lab/">try the Sim-Lab</a> while you wait.</p>
    )}
  </section>
</Base>

<style>
  .cat-hero { padding: 56px 0 32px; border-bottom: 1px solid var(--line); margin-bottom: 40px; }
  .cat-eyebrow { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--pc); }
  .cat-hero h1 { font-family: var(--font-display); font-size: clamp(32px, 4.5vw, 52px); font-weight: 800; letter-spacing: -0.03em; margin: 14px 0 12px; }
  .cat-hero > p { font-size: 16px; color: var(--text-mid); max-width: 620px; line-height: 1.6; }
  .cat-subnav { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 22px; }
  .cat-subnav a { font-family: var(--font-mono); font-size: 11.5px; letter-spacing: 0.06em; padding: 7px 14px; border: 1px solid var(--bg-4); border-radius: 100px; color: var(--text-mid); }
  .cat-subnav a:hover { border-color: var(--pc); color: var(--pc); }
  .cat-group { margin-bottom: 44px; scroll-margin-top: 88px; }
  .cat-group h2 { font-family: var(--font-display); font-size: 22px; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 18px; }
  .cat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 14px; }
  .cat-card { display: flex; flex-direction: column; background: var(--bg-1); border: 1px solid var(--line); border-radius: var(--radius-sm); overflow: hidden; transition: border-color 0.15s, transform 0.15s; }
  .cat-card:hover { border-color: var(--green); transform: translateY(-2px); }
  /* Update 4.4.2 #3 — same 16:9 hatched placeholder convention as the Sim-Lab cards */
  .cat-media { position: relative; aspect-ratio: 16 / 9; display: grid; place-items: center; color: var(--text-faint);
    background: repeating-linear-gradient(135deg, var(--bg-2) 0 12px, var(--bg-1) 12px 24px);
    border-bottom: 1px solid var(--line); }
  .cat-media svg { opacity: 0.5; }
  .cat-media-tag { position: absolute; bottom: 8px; right: 10px; font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.1em; color: var(--text-faint); background: var(--bg-0); border: 1px solid var(--line); padding: 2px 6px; border-radius: 6px; }
  .cat-body { display: flex; flex-direction: column; gap: 8px; padding: 16px 18px 18px; flex-grow: 1; }
  .cat-card h3 { font-family: var(--font-display); font-size: 16.5px; font-weight: 700; line-height: 1.3; letter-spacing: -0.015em; }
  .cat-card p { font-size: 13px; color: var(--text-dim); line-height: 1.55; }
  .cat-card time { font-family: var(--font-mono); font-size: 10.5px; color: var(--text-faint); letter-spacing: 0.08em; margin-top: auto; }
  .cat-empty { color: var(--text-dim); padding: 24px 0 48px; }
  .cat-empty a { color: var(--green); text-decoration: underline; }
</style>
