<script>
  // #3 — lightweight, dependency-free chart tooltips.
  // Any element with .js-bar + data-tip shows a floating value on hover/focus.
  (() => {
    const bars = Array.from(document.querySelectorAll<HTMLElement>('.js-bar'));
    if (!bars.length) return;

    const tip = document.createElement('div');
    tip.className = 'chart-tip';
    tip.setAttribute('role', 'status');
    document.body.appendChild(tip);

    let raf = 0;
    function place(x: number, y: number) {
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(() => {
        const r = tip.getBoundingClientRect();
        let left = x - r.width / 2;
        left = Math.max(8, Math.min(left, window.innerWidth - r.width - 8));
        let top = y - r.height - 12;
        if (top < 8) top = y + 16; // flip below if no room above
        tip.style.left = `${left}px`;
        tip.style.top = `${top}px`;
      });
    }

    function show(el: HTMLElement, x: number, y: number) {
      const text = el.dataset.tip;
      if (!text) return;
      tip.textContent = text;
      tip.classList.add('show');
      place(x, y);
    }
    function hide() { tip.classList.remove('show'); }

    bars.forEach((bar) => {
      bar.addEventListener('mouseenter', (e) => show(bar, e.clientX, e.clientY));
      bar.addEventListener('mousemove', (e) => { if (tip.classList.contains('show')) place(e.clientX, e.clientY); });
      bar.addEventListener('mouseleave', hide);
      bar.addEventListener('focus', () => {
        const r = bar.getBoundingClientRect();
        show(bar, r.left + r.width / 2, r.top);
      });
      bar.addEventListener('blur', hide);
    });
    window.addEventListener('scroll', hide, { passive: true });
  })();
</script>

