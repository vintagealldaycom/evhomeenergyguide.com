---
import Base from '../layouts/Base.astro';
import ChargingCostCalculator from '../components/tools/ChargingCostCalculator.astro';
import ShareBar from '../components/ShareBar.astro';
import { getCollection } from 'astro:content';
import { site, pillars, heroArticle } from '../config/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latest = posts.slice(0, 6);

const photoClass: Record<string, string> = {
  'ev-home-charging': 'photo-charge',
  'smart-home-energy': 'photo-home',
  'solar-battery-backup': 'photo-solar',
  'ev-travel-camping': 'photo-camp',
  'cordless-tools-workshop': 'photo-tools',
};

// Hero attention chart: range added per hour by charge level (DOE/AFDC figures).
const chargeLevels = [
  { label: 'Level 1 · 120V', miles: 4, note: '3–5 mi/hr', color: 'var(--amber)' },
  { label: 'Level 2 · 240V', miles: 30, note: '~30 mi/hr', color: 'var(--green)' },
  { label: 'DC Fast', miles: 200, note: '200+ mi / 30 min', color: 'var(--blue)' },
];
const maxMiles = Math.max(...chargeLevels.map((c) => c.miles));

// #4 STAT BAND — real EV/home-energy data. Figures verified against government
// sources (EIA, DOE/AFDC, US DOT FHWA, NREL). Update 4.4.1: stats are now
// interactive — each cell shows its source (from SOURCES_PRIVATE_2.md) on
// hover/tap with a link to the original data.
const energyStats = [
  { num: '17.9¢', unit: 'per kWh', label: 'Avg. U.S. home electricity rate', sub: 'National residential average, 2026', src: 'U.S. EIA — Electric Power Monthly, Table 5.6.A', href: 'https://www.eia.gov/electricity/monthly/epm_table_grapher.php?t=epmt_5_6_a' },
  { num: '~80%', unit: '', label: 'of EV charging happens at home', sub: 'Overnight Level 2 is the norm', src: 'U.S. DOE — Alternative Fuels Data Center', href: 'https://afdc.energy.gov/fuels/electricity-charging-home' },
  { num: '3–5¢', unit: 'per mile', label: 'Typical home charging cost', sub: 'Roughly a third of gasoline', src: 'U.S. DOE — eGallon / FuelEconomy.gov', href: 'https://www.fueleconomy.gov/feg/Find.do?action=bt2' },
  { num: '~30', unit: 'mi/hr', label: 'Range added on Level 2 (240V)', sub: 'vs. 3–5 mi/hr on Level 1', src: 'U.S. DOT — Rural EV Toolkit (charging speeds)', href: 'https://www.transportation.gov/rural/ev/toolkit/ev-basics/charging-speeds' },
  { num: '20', unit: 'min', label: 'DC fast charge to 80%', sub: 'At high-power public stations', src: 'U.S. DOT — Rural EV Toolkit (charging speeds)', href: 'https://www.transportation.gov/rural/ev/toolkit/ev-basics/charging-speeds' },
  { num: '37', unit: 'miles', label: 'Avg. miles driven per day (U.S.)', sub: 'Well within a nightly charge', src: 'U.S. DOT FHWA — National Household Travel Survey', href: 'https://nhts.ornl.gov/' },
  { num: '4–5', unit: 'hrs/day', label: 'Avg. U.S. peak sun hours', sub: 'What sizes a solar array', src: 'NREL — PVWatts / NSRDB solar resource data', href: 'https://pvwatts.nrel.gov/' },
  { num: '9.6', unit: 'kW', label: 'Top EV onboard power output', sub: 'Run a campsite or your home', src: 'Ford — F-150 Lightning Pro Power Onboard spec', href: 'https://www.ford.com/trucks/f150/f150-lightning/' },
];

// #6 EV CAMPING comparison — V2L output, usable battery, EPA range, approx price.
// Approximate; varies by trim & model year. Sources kept private (see
// SOURCES_PRIVATE_2.md). "Read more" points at the V2L camping guide.
const evCamping = [
  { name: 'Ford F-150 Lightning', v2l: '9.6 kW', battery: '~131 kWh', range: '~320 mi', price: '~$63k', best: true },
  { name: 'Chevrolet Silverado EV', v2l: '7.2 kW', battery: '~205 kWh', range: '~450 mi', price: '~$75k', best: false },
  { name: 'Kia EV9', v2l: '3.6 kW', battery: '~100 kWh', range: '~304 mi', price: '~$56k', best: false },
  { name: 'Hyundai Ioniq 5', v2l: '3.6 kW', battery: '~84 kWh', range: '~318 mi', price: '~$43k', best: true },
  { name: 'Kia EV6', v2l: '3.6 kW', battery: '~84 kWh', range: '~319 mi', price: '~$43k', best: false },
  { name: 'Rivian R1T', v2l: '1.5 kW', battery: '~141 kWh', range: '~420 mi', price: '~$70k', best: false },
];

// Typical home usage breakdown (illustrative, links to the monitors guide)
const usage = [
  { label: 'EV charging', pct: 32, color: 'var(--green)' },
  { label: 'Heating & cooling', pct: 24, color: 'var(--blue)' },
  { label: 'Water heater', pct: 13, color: 'var(--amber)' },
  { label: 'Kitchen & laundry', pct: 12, color: 'var(--orange)' },
  { label: 'Lighting & electronics', pct: 10, color: 'var(--purple)' },
  { label: 'Phantom loads', pct: 9, color: 'var(--pink)' },
];

// Illustrative monthly total for a typical EV home. Used only to turn the
// usage percentages into concrete kWh figures on hover — clearly labelled
// "illustrative" in the UI, not a claim of precision.
const MONTHLY_KWH = 900;
---

<Base title={`${site.name} — ${site.tagline}`} description={site.description}>
  <!-- HERO (v2 — featured L1 vs L2 guide with attention chart) -->
  <section class="hero-home container">
    <div class="hero-copy">
      <span class="hero-eyebrow">Your Path to an Electric Home, Simplified.</span>
      <h1>Power your life <em>smarter</em> and further.</h1>
      <p class="hero-manual-line">The electric home manual you never got, written for the average owner.</p>
      <p>
        Your path to an electric home, simplified. Connecting your EV, solar, and battery
        storage into one efficient system. From home chargers and solar gear to cordless
        tool batteries and EV road trips — learn it all in one place.
      </p>
      <div class="hero-actions">
        <a href="/en/sim-lab/" class="btn btn-primary">Try the Sim-Lab</a>
        <a href="#pillars" class="btn btn-ghost">Browse the guides</a>
      </div>
    </div>

    <a
      href={heroArticle.url}
      class="hero-featured"
      target={heroArticle.external ? '_blank' : undefined}
      rel={heroArticle.external ? 'noopener' : undefined}
    >
      <span class="pill-tag">● {heroArticle.eyebrow}</span>
      <h2>{heroArticle.title}</h2>
      <p>{heroArticle.blurb}</p>

      <div class="hero-chart" role="img" aria-label="Range added per hour of charging: Level 1 about 4 miles, Level 2 about 30 miles, DC fast charging 200 plus miles in 30 minutes">
        <span class="hero-chart-cap">Range added per hour of charging</span>
        {chargeLevels.map((c) => (
          <div
            class="hc-row js-bar"
            tabindex="0"
            data-tip={`${c.label} · ${c.note}`}
            aria-label={`${c.label}: ${c.note}`}
          >
            <span class="hc-label">{c.label}</span>
            <span class="hc-track"><span class="hc-fill" style={`width:${Math.max((c.miles / maxMiles) * 100, 6)}%; background:${c.color}`}></span></span>
            <span class="hc-note" style={`color:${c.color}`}>{c.note}</span>
          </div>
        ))}
      </div>
      <span class="hero-featured-cta">Read the full comparison →</span>
    </a>
  </section>

  <!-- #8 — CALCULATOR AS FOCUS POINT (moved directly under the hero) -->
  <section class="container try-section">
    <div class="try-copy">
      <span class="section-eyebrow">Try it right now — free</span>
      <h2>What does home charging <em>really</em> cost you?</h2>
      <p>
        Most drivers overestimate it. Type your battery size, your electric rate, and your
        monthly miles — the answer updates instantly. Then share your number.
      </p>
      <ul class="try-facts">
        <li>Home charging typically runs <strong>3–5¢ per mile</strong> — a third of gasoline.</li>
        <li>Overnight time-of-use rates can cut that <strong>nearly in half</strong> again.</li>
        <li>Level 1 vs Level 2 costs the same per kWh — the difference is <strong>speed</strong>.</li>
      </ul>
    </div>
    <div class="try-tool">
      <ChargingCostCalculator />
      <ShareBar label="My EV home charging cost" resultId="cc-share-result" />
      <a href="/en/sim-lab/" class="try-more">More tools in the Sim-Lab →</a>
    </div>
  </section>

  <!-- #4 — STAT BAND (EV & home-energy data) -->
  <section class="container stat-section">
    <div class="stat-head">
      <span class="section-eyebrow">The numbers that matter</span>
      <h2>National Energy Benchmarks</h2>
    </div>
    <div class="stat-grid">
      {energyStats.map((s) => (
        <div class="stat-cell" tabindex="0">
          <span class="stat-num">{s.num}{s.unit && <em>{s.unit}</em>}</span>
          <span class="stat-label">{s.label}</span>
          <span class="stat-sub">{s.sub}</span>
          <span class="stat-src-hint" aria-hidden="true">ⓘ</span>
          <span class="stat-src">
            <span class="stat-src-name">{s.src}</span>
            <a href={s.href} target="_blank" rel="noopener nofollow">View source ↗</a>
          </span>
        </div>
      ))}
    </div>
  </section>

  <!-- THE ELECTRIC HOME MANUAL (update 4.4.1 #2) -->
  <section class="container manual-section">
    <div class="manual-grid">
      <div class="manual-copy">
        <span class="section-eyebrow">The Electric Home Manual</span>
        <p>
          Owning an electric home shouldn't be a DIY research project. We curate the complex
          technical data into plain-English guides and interactive simulators, helping you put
          your energy assets to work—saving you money, reducing your footprint, and making you
          the expert for your family and friends.
        </p>
      </div>
      {/* Update 4.4.2 #1 — interactive SVG dashboard: hover/tap an energy asset to light it up */}
      <div class="manual-viz">
        <svg viewBox="0 0 400 240" width="100%" height="100%" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Interactive schematic of a home energy system: solar panels, main panel, home battery, and EV charger">
          <!-- ground -->
          <line x1="16" y1="208" x2="384" y2="208" stroke="var(--line)" stroke-width="1.5" />
          <!-- house shell -->
          <g stroke="var(--text-mid)" stroke-width="1.8" fill="rgba(240,237,228,0.04)" stroke-linejoin="round">
            <path d="M70 208 L70 110 L165 56 L260 110 L260 208 Z" />
            <rect x="196" y="152" width="30" height="56" fill="rgba(0,0,0,0.25)" stroke-width="1.4" />
            <rect x="90" y="150" width="26" height="22" fill="rgba(96,165,250,0.10)" stroke-width="1.4" />
          </g>

          <!-- energy flow wires (light up with their asset) -->
          <path class="viz-wire wire-solar" d="M150 84 L150 118" fill="none" stroke="var(--line)" stroke-width="1.6" stroke-dasharray="3 3" />
          <path class="viz-wire wire-batt" d="M148 132 Q120 138 106 182" fill="none" stroke="var(--line)" stroke-width="1.6" stroke-dasharray="3 3" />
          <path class="viz-wire wire-ev" d="M162 132 Q240 140 296 172" fill="none" stroke="var(--line)" stroke-width="1.6" stroke-dasharray="3 3" />

          <!-- SOLAR PANELS (roof) -->
          <g class="viz-asset" data-asset="solar" tabindex="0" role="button" aria-label="Solar panels">
            <path class="viz-shape" d="M108 104 L162 72 L212 100 L158 132 Z" fill="rgba(96,165,250,0.12)" stroke="var(--blue)" stroke-width="1.6" stroke-linejoin="round" />
            <path d="M132 90 L184 118 M128 116 L182 86 M146 82 L198 110" stroke="var(--blue)" stroke-width="0.9" fill="none" opacity="0.7" />
            <g class="viz-tag" transform="translate(96 40)">
              <rect x="0" y="0" width="88" height="20" rx="10" fill="var(--bg-2)" stroke="rgba(96,165,250,0.5)" stroke-width="1" />
              <text x="44" y="13.5" text-anchor="middle" fill="var(--blue)" font-size="10" font-family="var(--font-mono)">SOLAR ARRAY</text>
            </g>
          </g>

          <!-- MAIN PANEL (on house wall) -->
          <g class="viz-asset" data-asset="panel" tabindex="0" role="button" aria-label="Main electrical panel">
            <rect class="viz-shape" x="142" y="116" width="26" height="34" rx="3" fill="rgba(251,191,36,0.12)" stroke="var(--amber)" stroke-width="1.6" />
            <line x1="148" y1="124" x2="162" y2="124" stroke="var(--amber)" stroke-width="1.4" />
            <line x1="148" y1="131" x2="162" y2="131" stroke="var(--amber)" stroke-width="1.4" />
            <line x1="148" y1="138" x2="162" y2="138" stroke="var(--amber)" stroke-width="1.4" />
            <g class="viz-tag" transform="translate(112 158)">
              <rect x="0" y="0" width="84" height="20" rx="10" fill="var(--bg-2)" stroke="rgba(251,191,36,0.5)" stroke-width="1" />
              <text x="42" y="13.5" text-anchor="middle" fill="var(--amber)" font-size="10" font-family="var(--font-mono)">MAIN PANEL</text>
            </g>
          </g>

          <!-- HOME BATTERY (wall unit) -->
          <g class="viz-asset" data-asset="battery" tabindex="0" role="button" aria-label="Home battery">
            <rect class="viz-shape" x="96" y="180" width="20" height="28" rx="3" fill="var(--green-soft)" stroke="var(--green)" stroke-width="1.6" />
            <path d="M109 185 L102 195 L106 195 L103 203 L110 193 L106 193 Z" fill="var(--green)" />
            <g class="viz-tag" transform="translate(20 158)">
              <rect x="0" y="0" width="88" height="20" rx="10" fill="var(--bg-2)" stroke="rgba(74,222,128,0.5)" stroke-width="1" />
              <text x="44" y="13.5" text-anchor="middle" fill="var(--green)" font-size="10" font-family="var(--font-mono)">HOME BATTERY</text>
            </g>
          </g>

          <!-- EV + CHARGER -->
          <g class="viz-asset" data-asset="ev" tabindex="0" role="button" aria-label="EV charger">
            <rect class="viz-shape" x="290" y="168" width="12" height="24" rx="2" fill="var(--green-soft)" stroke="var(--green)" stroke-width="1.5" />
            <path class="viz-wire wire-cord" d="M302 176 Q314 176 318 186" fill="none" stroke="var(--line)" stroke-width="1.5" stroke-dasharray="3 3" />
            <g stroke="var(--text-mid)" stroke-width="1.7" fill="rgba(240,237,228,0.05)" stroke-linejoin="round">
              <path d="M316 208 L316 194 Q316 189 322 189 L336 189 L344 180 L368 180 L376 189 L386 189 Q392 189 392 194 L392 208 Z" transform="translate(-8 0)" />
            </g>
            <circle cx="322" cy="208" r="7" fill="var(--bg-0)" stroke="var(--text-mid)" stroke-width="1.7" />
            <circle cx="372" cy="208" r="7" fill="var(--bg-0)" stroke="var(--text-mid)" stroke-width="1.7" />
            <g class="viz-tag" transform="translate(296 140)">
              <rect x="0" y="0" width="82" height="20" rx="10" fill="var(--bg-2)" stroke="rgba(74,222,128,0.5)" stroke-width="1" />
              <text x="41" y="13.5" text-anchor="middle" fill="var(--green)" font-size="10" font-family="var(--font-mono)">EV CHARGER</text>
            </g>
          </g>
        </svg>
        <span class="manual-viz-hint">Hover or tap an asset to see it light up</span>
      </div>
    </div>
  </section>

  <!-- #7 — 5 PILLARS (below the fold; clear separation) -->
  <div class="pillar-divider" aria-hidden="true"></div>
  <section id="pillars" class="container pillars-section">
    <div class="pillars-head">
      <span class="section-eyebrow">Explore the guides</span>
      <h2 class="section-title">Five paths. One electric home.</h2>
      <p class="pillars-intro">Pick where you are today — each path connects to the rest of your home's energy system.</p>
    </div>
    <div class="pillar-grid">
      {pillars.map((p) => (
        <a href={`/category/${p.slug}/`} class="pillar-card" style={`--pc:${p.color}`}>
          <h3>{p.title}</h3>
          <p>{p.description}</p>
          <ul>
            {p.subcategories.map((s) => <li>{s}</li>)}
          </ul>
          <span class="pillar-cta">Explore →</span>
        </a>
      ))}
    </div>
  </section>

  <!-- #5 — split into two self-titled cards (combined header dropped) -->
  <section class="container monitor-section">
    <div class="monitor-grid">
      <!-- CHART: usage breakdown — interactive (#3) -->
      <a href="/blog/smart-energy-monitors-guide/" class="monitor-card" aria-label="Read the smart energy monitors guide">
        <span class="monitor-kicker">Where Your Power Goes</span>
        <h3>A typical EV home's monthly usage</h3>
        <div class="usage-chart" role="img" aria-label="Bar chart of home electricity usage by category, illustrative for a 900 kilowatt-hour month">
          {usage.map((u) => {
            const kwh = Math.round((MONTHLY_KWH * u.pct) / 100);
            return (
              <div
                class="usage-row js-bar"
                tabindex="0"
                data-tip={`${u.label}: ${kwh} kWh · ${u.pct}%`}
                aria-label={`${u.label}: about ${kwh} kilowatt-hours, ${u.pct} percent`}
              >
                <span class="usage-label">{u.label}</span>
                <span class="usage-track"><span class="usage-fill" style={`width:${u.pct * 2.6}%; background:${u.color}`}></span></span>
                <span class="usage-pct" style={`color:${u.color}`}>{u.pct}%</span>
              </div>
            );
          })}
        </div>
        <span class="usage-basis">Illustrative — based on a typical ~{MONTHLY_KWH} kWh/mo EV home. Hover a bar for kWh.</span>
        <!-- Update 4.3.2 — schematic: home + solar + battery + EV, matches camp-scene style -->
        <div class="home-scene" aria-hidden="true">
          <svg viewBox="0 0 400 130" width="100%" height="100%" preserveAspectRatio="xMidYMid meet" role="img">
            <defs>
              <linearGradient id="homeSky" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="rgba(74,222,128,0.10)" />
                <stop offset="1" stop-color="rgba(74,222,128,0)" />
              </linearGradient>
            </defs>
            <rect x="0" y="0" width="400" height="130" fill="url(#homeSky)" />
            <!-- sun -->
            <g stroke="var(--amber)" stroke-width="1.5" opacity="0.75" fill="none">
              <circle cx="52" cy="30" r="10" />
              <line x1="52" y1="12" x2="52" y2="16" /><line x1="52" y1="44" x2="52" y2="48" />
              <line x1="34" y1="30" x2="38" y2="30" /><line x1="66" y1="30" x2="70" y2="30" />
              <line x1="39" y1="17" x2="42" y2="20" /><line x1="62" y1="40" x2="65" y2="43" />
              <line x1="65" y1="17" x2="62" y2="20" /><line x1="42" y1="40" x2="39" y2="43" />
            </g>
            <!-- ground line -->
            <line x1="0" y1="104" x2="400" y2="104" stroke="var(--line)" stroke-width="1.5" />
            <!-- house -->
            <g stroke="var(--text-mid)" stroke-width="1.8" fill="rgba(240,237,228,0.05)" stroke-linejoin="round">
              <path d="M118 104 L118 60 L160 36 L202 60 L202 104 Z" />
              <rect x="132" y="76" width="16" height="14" fill="rgba(96,165,250,0.12)" stroke-width="1.4" />
              <rect x="170" y="76" width="18" height="28" fill="rgba(0,0,0,0.25)" stroke-width="1.4" />
            </g>
            <!-- solar panel on roof -->
            <g stroke="var(--blue)" stroke-width="1.5" fill="rgba(96,165,250,0.12)" stroke-linejoin="round">
              <path d="M136 58 L162 43 L184 55 L158 70 Z" />
              <path d="M149 51 L171 63 M147 62 L169 50" stroke-width="1" fill="none" />
            </g>
            <!-- home battery on wall -->
            <g stroke="var(--green)" stroke-width="1.5" stroke-linejoin="round">
              <rect x="207" y="74" width="14" height="26" rx="2" fill="var(--green-soft)" />
              <path d="M216 78 L211 86 L214 86 L212 94 L217 85 L214 85 Z" fill="var(--green)" stroke="none" />
            </g>
            <!-- charging cable: battery → EV -->
            <path d="M221 92 Q244 92 252 98" fill="none" stroke="var(--green)" stroke-width="1.6" stroke-dasharray="3 3" />
            <!-- EV -->
            <g stroke="var(--text-mid)" stroke-width="1.8" fill="rgba(240,237,228,0.05)" stroke-linejoin="round">
              <path d="M256 102 L256 88 Q256 83 263 83 L281 83 L291 73 L321 73 L331 83 L346 83 Q352 83 352 88 L352 102 Z" />
              <path d="M281 83 L291 75 L319 75 L327 83 Z" fill="rgba(96,165,250,0.12)" />
            </g>
            <circle cx="274" cy="102" r="8" fill="var(--bg-0)" stroke="var(--text-mid)" stroke-width="1.8" />
            <circle cx="334" cy="102" r="8" fill="var(--bg-0)" stroke="var(--text-mid)" stroke-width="1.8" />
            <!-- charge port bolt badge -->
            <g transform="translate(296 52)">
              <circle cx="6" cy="6" r="10" fill="var(--green-soft)" stroke="var(--green)" stroke-width="1.2" />
              <path d="M8 0 L2 7 L6 7 L4 12 L10 5 L6 5 L8 0 Z" fill="var(--green)" />
            </g>
          </svg>
        </div>
        <span class="monitor-link">See what a monitor catches that your bill hides →</span>
      </a>

      <!-- #6 — EV CAMPING comparison table, now with a #1 scene diagram -->
      <a href="/blog/ev-camping-v2l-setup/" class="monitor-card" aria-label="Read the EV camping V2L setup guide">
        <div class="camp-scene" aria-hidden="true">
          <svg viewBox="0 0 400 150" width="100%" height="100%" preserveAspectRatio="xMidYMid meet" role="img">
            <defs>
              <linearGradient id="campSky" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="rgba(74,222,128,0.10)" />
                <stop offset="1" stop-color="rgba(74,222,128,0)" />
              </linearGradient>
              <linearGradient id="campBolt" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0" stop-color="var(--green-bright)" />
                <stop offset="1" stop-color="var(--green)" />
              </linearGradient>
            </defs>
            <!-- sky wash -->
            <rect x="0" y="0" width="400" height="150" fill="url(#campSky)" />
            <!-- stars -->
            <circle cx="60" cy="26" r="1.3" fill="var(--text-faint)" />
            <circle cx="110" cy="16" r="1" fill="var(--text-faint)" />
            <circle cx="250" cy="22" r="1.2" fill="var(--text-faint)" />
            <circle cx="330" cy="30" r="1" fill="var(--text-faint)" />
            <circle cx="300" cy="14" r="1.4" fill="var(--text-faint)" />
            <!-- moon -->
            <circle cx="352" cy="34" r="13" fill="none" stroke="var(--amber)" stroke-width="1.5" opacity="0.7" />
            <!-- ground line -->
            <line x1="0" y1="120" x2="400" y2="120" stroke="var(--line)" stroke-width="1.5" />
            <!-- pine trees -->
            <g fill="none" stroke="var(--green)" stroke-width="1.6" opacity="0.6" stroke-linejoin="round">
              <path d="M40 120 L40 92 M40 96 L30 108 L50 108 Z M40 88 L32 100 L48 100 Z" />
              <path d="M70 120 L70 100 M70 102 L62 112 L78 112 Z" />
            </g>
            <!-- tent -->
