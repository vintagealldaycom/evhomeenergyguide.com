---
import Base from '../../../layouts/Base.astro';
import { tools, toolGroups, calculatorUrl } from '../../../config/tools';

// Micro-Feature Row (update 4.3.2) — replaces the old feature pills.
// Icon + bold headline + micro-copy, reads like a product landing page.
const features = [
  {
    label: 'Free Forever',
    copy: 'No sign-ups, no paywalls, no credit cards required.',
    icon: 'M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm1 15v1.5h-2V17c-1.7-.3-3-1.3-3-3h2c0 .8 1 1.2 2 1.2s2-.4 2-1.2c0-.7-.7-1-2.3-1.4C10 12.2 8 11.7 8 9.8 8 8.3 9.3 7.3 11 7V5.5h2V7c1.7.3 3 1.3 3 2.8h-2c0-.7-1-1-2-1s-2 .3-2 1c0 .6.7.9 2.3 1.3 1.7.4 3.7 1 3.7 2.9 0 1.6-1.3 2.7-3 3z',
    color: 'var(--amber)',
    bg: 'rgba(251,191,36,0.12)',
  },
  {
    label: '100% Interactive',
    copy: 'Instant, live results calculated entirely in your browser.',
    icon: 'M13 2 3 14h7l-1 8 10-12h-7l1-8z',
    color: 'var(--green)',
    bg: 'var(--green-soft)',
  },
  {
    label: 'Zero Data Tracking',
    copy: 'Your entries stay local. Nothing is ever saved or sent to a server.',
    icon: 'M12 2 4 5v6c0 5 3.4 9.7 8 11 4.6-1.3 8-6 8-11V5l-8-3zm0 2.2 6 2.25V11c0 3.9-2.5 7.6-6 8.8-3.5-1.2-6-4.9-6-8.8V6.45L12 4.2z',
    color: 'var(--blue)',
    bg: 'rgba(96,165,250,0.12)',
  },
];
---

<Base
  title="Sim-Lab — EV Home Energy Calculators & Simulators"
  description="The Sim-Lab: free, interactive EV and home energy tools — charging cost, solar & battery sizing, EV vs gas, TOU savings and more. Everything runs in your browser; nothing is saved or sent."
>
  <!-- APP HERO -->
  <section class="container app-hero">
    <div class="app-hero-copy">
      <span class="app-eyebrow">⚡ Interactive Calculators &amp; Simulators</span>
      <h1>Sim-Lab</h1>
      <p class="app-tagline">Run the numbers. Make the decision.</p>
      <p>
        Explore the Sim-Lab—our library of free, interactive tools designed to help you
        estimate EV charging costs, plan home energy upgrades, size battery backups, and
        compare equipment. Every simulation is powered by the same verified data found in
        our guides, runs directly in your browser, and keeps your information private—nothing
        is saved or sent anywhere.
      </p>
      <div class="app-features">
        {features.map((f) => (
          <div class="feature-item">
            <span class="feature-icon" style={`color:${f.color}; background:${f.bg}`}>
              <svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor" aria-hidden="true"><path d={f.icon}/></svg>
            </span>
            <div class="feature-text">
              <strong>{f.label}</strong>
              <small>{f.copy}</small>
            </div>
          </div>
        ))}
      </div>
    </div>
    <div class="app-hero-visual" aria-hidden="true">
      <div class="orbit">
        <div class="orbit-core">
          <svg viewBox="0 0 24 24" width="42" height="42" fill="var(--green)"><path d="M13 2 3 14h7l-1 8 10-12h-7l1-8z"/></svg>
        </div>
        {tools.slice(0, 6).map((t, i) => (
          <div class={`orbit-dot d${i + 1}`}>
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d={t.icon}/></svg>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FILTER CHIPS -->
  <section class="container">
    <div class="filter-bar" role="tablist" aria-label="Filter Sim-Lab tools by category">
      {toolGroups.map((g, i) => (
        <button class:list={['chip', { active: i === 0 }]} data-group={g} role="tab" aria-selected={i === 0 ? 'true' : 'false'}>
          {g}
          <span class="chip-count">{g === 'All Tools' ? tools.length : tools.filter((t) => t.group === g).length}</span>
        </button>
      ))}
    </div>

    <!-- CALCULATOR DIRECTORY -->
    <div class="tool-directory">
      {tools.map((t) => (
        <article class:list={['dir-card', { live: t.status === 'live' }]} data-group={t.group}>
          {/* #11 — 16:9 image placeholder (1200×675). Swap in a real image later. */}
          <div class="calc-media" data-status={t.status} aria-hidden="true">
            <svg class="calc-media-icon" viewBox="0 0 24 24" width="40" height="40" fill="currentColor"><path d={t.icon}/></svg>
            <span class="calc-media-tag">1200 × 675</span>
          </div>
          <div class="dir-body">
            <div class="dir-tags">
              {t.badge && <span class:list={['dir-badge', t.badge.toLowerCase()]}>★ {t.badge}</span>}
              <span class="dir-group">{t.group}</span>
            </div>
            <h3>{t.name}</h3>
            <p>{t.description}</p>
            <div class="dir-foot">
              <span class="dir-spec">{t.inputs}</span>
              {t.status === 'live' ? (
                <a href={calculatorUrl(t)} class="dir-launch">Open calculator →</a>
              ) : (
                <span class="dir-soon-cta">Coming soon</span>
              )}
            </div>
          </div>
        </article>
      ))}
      <p class="dir-empty" hidden>More tools for this category are on the way. Check back soon.</p>
    </div>
  </section>

  <!-- SUGGEST (#12) -->
  <section class="container">
    <div class="suggest-band">
      <div>
        <h2>Building the future of home energy, together.</h2>
        <p>Have a specific simulation you need?</p>
      </div>
      <a href="/contact/" class="btn-suggest">Suggest a tool →</a>
    </div>
  </section>
</Base>

<script>
  // Category filter
  const chips = document.querySelectorAll<HTMLButtonElement>('.chip');
  const cards = document.querySelectorAll<HTMLElement>('.dir-card');
  const empty = document.querySelector<HTMLElement>('.dir-empty');
  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      chips.forEach((c) => { c.classList.remove('active'); c.setAttribute('aria-selected', 'false'); });
      chip.classList.add('active');
      chip.setAttribute('aria-selected', 'true');
      const g = chip.dataset.group;
      let shown = 0;
      cards.forEach((card) => {
        const match = g === 'All Tools' || card.dataset.group === g;
        card.style.display = match ? '' : 'none';
        if (match) shown++;
      });
      if (empty) empty.hidden = shown > 0;
    });
  });
</script>

<style>
  .app-hero { display: grid; grid-template-columns: 1.3fr 1fr; gap: 40px; align-items: center; padding: 56px 0 40px; border-bottom: 1px solid var(--line); }
  .app-eyebrow { display: inline-block; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--green); padding: 7px 14px; background: var(--green-soft); border: 1px solid rgba(74,222,128,0.3); border-radius: 100px; margin-bottom: 20px; }
  .app-hero h1 { font-family: var(--font-display); font-size: clamp(30px, 4vw, 46px); font-weight: 800; letter-spacing: -0.035em; line-height: 1.05; margin-bottom: 8px; }
  .app-tagline { font-family: var(--font-display); font-size: 18px; font-weight: 700; color: var(--green); margin-bottom: 14px; }
  .app-hero-copy > p { font-size: 15.5px; color: var(--text-mid); line-height: 1.65; max-width: 560px; margin-bottom: 26px; }
  /* Micro-Feature Row (update 4.3.2) */
  .app-features { display: flex; gap: 26px; border-top: 1px solid var(--line); padding-top: 22px; }
  .feature-item { display: flex; align-items: flex-start; gap: 11px; min-width: 0; flex: 1; }
  .feature-icon {
    flex-shrink: 0; display: grid; place-items: center;
    width: 36px; height: 36px; border-radius: 10px;
  }
  .feature-text { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
  .feature-text strong {
    font-family: var(--font-display); font-size: 14px; font-weight: 700;
    letter-spacing: -0.01em; color: var(--text); line-height: 1.2;
  }
  .feature-text small { font-size: 12px; color: var(--text-dim); line-height: 1.45; }

  .orbit { position: relative; width: 300px; height: 300px; margin: 0 auto; border: 1px dashed var(--bg-4); border-radius: 50%; }
  .orbit-core { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 92px; height: 92px; display: grid; place-items: center; background: var(--bg-1); border: 1px solid rgba(74,222,128,0.4); border-radius: 24px; box-shadow: 0 0 42px rgba(74,222,128,0.18); }
  .orbit-dot { position: absolute; width: 42px; height: 42px; display: grid; place-items: center; background: var(--bg-2); border: 1px solid var(--bg-4); border-radius: 12px; color: var(--text-dim); }
  .orbit-dot.d1 { top: -21px; left: 50%; transform: translateX(-50%); color: var(--green); }
  .orbit-dot.d2 { top: 18%; right: -8px; color: var(--blue); }
  .orbit-dot.d3 { bottom: 18%; right: -8px; color: var(--amber); }
  .orbit-dot.d4 { bottom: -21px; left: 50%; transform: translateX(-50%); color: var(--orange); }
  .orbit-dot.d5 { bottom: 18%; left: -8px; color: var(--purple); }
  .orbit-dot.d6 { top: 18%; left: -8px; color: var(--pink); }

  /* Orbit animation (update 4.3.2) — pure CSS, transform/opacity only (GPU-composited).
     The core bolt pulses; each dot gently floats with a staggered delay. */
  .orbit-core { animation: core-pulse 3.4s ease-in-out infinite; }
  .orbit-core svg { animation: bolt-flicker 3.4s ease-in-out infinite; }
  .orbit-dot { animation: dot-float 4.5s ease-in-out infinite; will-change: transform; }
  .orbit-dot.d1 { animation: dot-float-x 4.5s ease-in-out infinite; }
  .orbit-dot.d4 { animation: dot-float-x 4.5s ease-in-out infinite; animation-delay: 2.25s; }
  .orbit-dot.d2 { animation-delay: 0.75s; }
  .orbit-dot.d3 { animation-delay: 1.5s; }
  .orbit-dot.d5 { animation-delay: 3s; }
  .orbit-dot.d6 { animation-delay: 3.75s; }

  @keyframes core-pulse {
    0%, 100% { box-shadow: 0 0 42px rgba(74,222,128,0.18); }
    50% { box-shadow: 0 0 58px rgba(74,222,128,0.34); }
  }
  @keyframes bolt-flicker {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.85; transform: scale(1.06); }
  }
  /* d1/d4 sit on the vertical axis with translateX(-50%) — preserve it while floating */
  @keyframes dot-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  @keyframes dot-float-x {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(-6px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .orbit-core, .orbit-core svg, .orbit-dot { animation: none; }
  }

  .filter-bar { display: flex; gap: 8px; flex-wrap: wrap; padding: 28px 0 24px; position: sticky; top: 84px; background: var(--bg-0); z-index: 10; }
  .chip { display: inline-flex; align-items: center; gap: 8px; padding: 9px 16px; border: 1px solid var(--bg-4); border-radius: 100px; font-size: 13px; font-weight: 500; color: var(--text-mid); transition: border-color 0.15s, color 0.15s, background 0.15s; }
  .chip:hover { border-color: var(--green); color: var(--text); }
  .chip.active { background: var(--green); border-color: var(--green); color: #06220f; font-weight: 700; }
  .chip-count { font-family: var(--font-mono); font-size: 10px; opacity: 0.7; }

  .tool-directory { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; padding-bottom: 24px; }
  .dir-card { position: relative; display: flex; flex-direction: column; background: var(--bg-1); border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; transition: border-color 0.15s, transform 0.15s; }
  .dir-card.live:hover { border-color: var(--green); transform: translateY(-3px); }
  .dir-card.live { cursor: pointer; }
  .dir-card:not(.live) { opacity: 0.9; }
  /* Update 4.4.2 #4 — stretched link: the whole live card is clickable, not just the text */
  .dir-launch::after { content: ''; position: absolute; inset: 0; z-index: 1; }

  /* #11 — image placeholder: fixed 16:9 (1200×675) so every card aligns */
  .calc-media { position: relative; aspect-ratio: 16 / 9; display: grid; place-items: center; color: var(--text-faint);
    background:
      repeating-linear-gradient(135deg, var(--bg-2) 0 12px, var(--bg-1) 12px 24px);
    border-bottom: 1px solid var(--line); }
  .calc-media[data-status='live'] { color: var(--green); background: repeating-linear-gradient(135deg, rgba(74,222,128,0.08) 0 12px, var(--bg-1) 12px 24px); }
  .calc-media-icon { opacity: 0.55; }
  .calc-media-tag { position: absolute; bottom: 8px; right: 10px; font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.1em; color: var(--text-faint); background: var(--bg-0); border: 1px solid var(--line); padding: 2px 6px; border-radius: 6px; }

  .dir-body { display: flex; flex-direction: column; gap: 10px; padding: 18px 20px 20px; flex-grow: 1; }
  .dir-tags { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
  .dir-badge { font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; padding: 3px 8px; border-radius: 100px; }
  .dir-badge.popular { color: var(--amber); background: rgba(251,191,36,0.12); }
  .dir-badge.new { color: var(--green); background: var(--green-soft); }
  .dir-group { font-family: var(--font-mono); font-size: 9.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-faint); }
  .dir-card h3 { font-family: var(--font-display); font-size: 17px; font-weight: 700; letter-spacing: -0.02em; line-height: 1.25; }
  .dir-body > p { font-size: 13px; color: var(--text-dim); line-height: 1.55; flex-grow: 1; }
  .dir-foot { display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--line-soft); padding-top: 12px; }
  .dir-spec { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.08em; color: var(--text-faint); }
  .dir-launch { font-size: 13px; font-weight: 700; color: var(--green); }
  .dir-card.live:hover .dir-launch { color: var(--green-bright); }
  .dir-soon-cta { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-dim); }
  .dir-empty { grid-column: 1 / -1; padding: 40px 20px; text-align: center; color: var(--text-dim); font-size: 14px; border: 1px dashed var(--bg-4); border-radius: var(--radius); }

  .suggest-band { display: flex; justify-content: space-between; align-items: center; gap: 32px; margin: 48px 0 8px; padding: 32px 36px; border: 1px solid var(--line); border-radius: var(--radius); background: linear-gradient(120deg, var(--bg-1) 55%, rgba(74,222,128,0.07)); }
  .suggest-band h2 { font-family: var(--font-display); font-size: 22px; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 8px; }
  .suggest-band p { font-size: 14px; color: var(--text-mid); line-height: 1.6; max-width: 560px; }
  .btn-suggest { flex-shrink: 0; background: var(--green); color: #06220f; font-weight: 700; font-size: 14px; padding: 13px 24px; border-radius: 100px; transition: background 0.15s; }
  .btn-suggest:hover { background: var(--green-bright); }

  @media (max-width: 1000px) {
    .app-hero { grid-template-columns: 1fr; gap: 8px; padding: 40px 0 32px; }
    .app-hero-visual { display: none; }
    .tool-directory { grid-template-columns: repeat(2, 1fr); }
    .filter-bar { top: 68px; }
  }
  @media (max-width: 640px) {
    .app-hero { padding: 22px 0 24px; }
    /* Responsive typography (update 4.3.2) — smaller H1 so the intro stays above the fold */
    .app-hero h1 { font-size: clamp(26px, 8.5vw, 32px); margin-bottom: 6px; }
    .app-eyebrow { font-size: 10px; padding: 5px 11px; margin-bottom: 14px; letter-spacing: 0.12em; }
    .app-tagline { font-size: 16px; margin-bottom: 10px; }
    .app-hero-copy > p { font-size: 14.5px; margin-bottom: 20px; }
    /* Micro-Feature Row stacks vertically — no awkward wrapping */
    .app-features { flex-direction: column; gap: 14px; padding-top: 18px; }
    .feature-icon { width: 32px; height: 32px; }

    /* #15 — chips become an edge-to-edge horizontal scroll strip */
    .filter-bar {
      flex-wrap: nowrap; overflow-x: auto; scroll-snap-type: x proximity;
      -webkit-overflow-scrolling: touch; scrollbar-width: none;
      margin-inline: calc(-1 * var(--gutter)); padding: 18px var(--gutter) 18px;
      gap: 8px; top: 60px;
    }
    .filter-bar::-webkit-scrollbar { display: none; }
    .chip { flex-shrink: 0; scroll-snap-align: start; padding: 10px 16px; }

    .tool-directory { grid-template-columns: 1fr; }
    .suggest-band { flex-direction: column; align-items: flex-start; padding: 24px 22px; }
    .suggest-band h2 { font-size: 20px; }
  }
</style>
