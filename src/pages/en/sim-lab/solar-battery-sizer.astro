---
import Base from '../../../layouts/Base.astro';
import SolarBatterySizer from '../../../components/tools/SolarBatterySizer.astro';
import ShareBar from '../../../components/ShareBar.astro';
import { CALC_BASE } from '../../../config/tools';
---

<Base
  title="Solar & Battery Backup Sizer"
  description="Free solar and battery backup sizing calculator. Size a rooftop solar array (kW) and a home battery bank (kWh) to cover your daily usage and outage backup goals."
>
  <section class="container calc-page">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href={`${CALC_BASE}/`}>Sim-Lab</a>
      <span>/</span>
      <span aria-current="page">Solar &amp; Battery Backup Sizer</span>
    </nav>

    <header class="calc-head">
      <span class="calc-eyebrow">Solar · Calculator</span>
      <h1>Solar &amp; Battery Backup Sizer</h1>
      <p>
        Work out how big a solar array and battery bank you actually need. Enter your daily
        electricity use and how many days of backup you want, and get a target solar size (kW)
        and battery capacity (kWh) to plan around.
      </p>
    </header>

    <ShareBar label="Solar & Battery Backup Sizer" resultId="sb-share-result" />

    <div class="calc-embed">
      <SolarBatterySizer />
    </div>

    <section class="calc-notes">
      <h2>How to read your results</h2>
      <ul>
        <li><strong>Solar size (kW)</strong> is sized to replace your daily usage given average sun hours — cloudier regions need a larger array.</li>
        <li><strong>Battery capacity (kWh)</strong> covers your backup days; whole-home backup needs far more than essentials-only.</li>
        <li>Round <em>up</em> when buying — real-world losses, aging, and cold weather reduce usable capacity.</li>
      </ul>
      <p class="calc-disclaim">Estimates only — actual sizing depends on your roof, shading, local sun hours, and equipment. Always confirm with a certified installer.</p>
    </section>

    <a href={`${CALC_BASE}/`} class="calc-back">← Back to Sim-Lab</a>
  </section>
</Base>

<style>
  .calc-page { max-width: 960px; padding: 40px 0 24px; }
  .crumbs { display: flex; gap: 8px; align-items: center; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-faint); margin-bottom: 22px; }
  .crumbs a { color: var(--green); }
  .calc-head { margin-bottom: 22px; }
  .calc-eyebrow { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--green); }
  .calc-head h1 { font-family: var(--font-display); font-size: clamp(28px, 4vw, 42px); font-weight: 800; letter-spacing: -0.03em; margin: 10px 0 12px; }
  .calc-head p { font-size: 15.5px; color: var(--text-mid); line-height: 1.65; max-width: 680px; }
  .calc-embed { margin: 22px 0 8px; }
  .calc-embed :global(.tool) { margin: 0; }
  .calc-notes { margin-top: 36px; padding-top: 24px; border-top: 1px solid var(--line); }
  .calc-notes h2 { font-family: var(--font-display); font-size: 20px; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 14px; }
  .calc-notes ul { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 16px; }
  .calc-notes li { font-size: 14px; color: var(--text-mid); line-height: 1.6; padding-left: 16px; border-left: 2px solid var(--line); }
  .calc-notes strong { color: var(--text); }
  .calc-disclaim { font-size: 12.5px; color: var(--text-dim); line-height: 1.6; }
  .calc-back { display: inline-block; margin-top: 28px; font-size: 13.5px; font-weight: 600; color: var(--green); }
</style>
