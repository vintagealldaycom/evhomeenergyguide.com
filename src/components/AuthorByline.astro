---
import { author } from '../config/site';
interface Props { compact?: boolean }
const { compact = false } = Astro.props;
---

{compact ? (
  <div class="byline byline-compact">
    <img src={author.avatar} alt={author.name} width="36" height="36" loading="lazy" />
    <div>
      <p>By <strong><a href="/about/">{author.name}</a></strong></p>
      <p class="byline-title">{author.title}</p>
    </div>
  </div>
) : (
  <div class="byline byline-full">
    <img src={author.avatar} alt={author.name} width="52" height="52" loading="lazy" />
    <div>
      <p><strong>Written by <a href="/about/">{author.name}</a></strong></p>
      <p class="byline-title">{author.title}</p>
      <p class="byline-bio">{author.bio}</p>
    </div>
  </div>
)}

<style>
  .byline { display: flex; gap: 14px; align-items: flex-start; }
  .byline img { border-radius: 50%; background: var(--bg-3); object-fit: contain; padding: 6px; flex-shrink: 0; }
  .byline a { color: var(--green); }
  .byline p { margin: 0; font-size: 13.5px; }
  .byline-title { font-family: var(--font-mono); font-size: 11px !important; color: var(--text-dim); letter-spacing: 0.05em; margin-top: 2px !important; }
  .byline-bio { color: var(--text-mid); margin-top: 8px !important; line-height: 1.6; }
  .byline-full { border-top: 1px solid var(--line); padding-top: 24px; margin-top: 48px; }
</style>
