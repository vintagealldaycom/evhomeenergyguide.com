{
  "$ref": "#/definitions/guides",
  "definitions": {
    "guides": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 10,
          "maxLength": 70
        },
        "description": {
          "type": "string",
          "minLength": 50,
          "maxLength": 160
        },
        "pubDate": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "updatedDate": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "author": {
          "type": "string",
          "default": "Louis F."
        },
        "category": {
          "type": "string",
          "enum": [
            "ev-home-charging",
            "smart-home-energy",
            "solar-battery-backup",
            "ev-travel-camping",
            "cordless-tools-workshop"
          ]
        },
        "subcategory": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "image": {
          "type": "string"
        },
        "draft": {
          "type": "boolean",
          "default": false
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "description",
        "pubDate",
        "category"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}